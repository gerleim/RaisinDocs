<Window x:Class="RaisinDocs.Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docs="clr-namespace:RaisinDocs;assembly=RaisinDocs"
        Title="RaisinDocs Editor"
        Width="1024" Height="768"
        Background="#1E1E1E"
        Foreground="#D4D4D4">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#2D2D2D" Foreground="#D4D4D4">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="New_Click" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Click="Open_Click" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save" Click="Save_Click" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Click="SaveAs_Click" InputGestureText="Ctrl+Shift+S" />
            </MenuItem>
        </Menu>
        <docs:DocsEditor x:Name="Editor" ShowMinimap="True" Theme="DarkBlue">
            <docs:DocsEditor.Resources>
                <Style TargetType="docs:DocsFormattingBar"
                       BasedOn="{StaticResource {x:Type docs:DocsFormattingBar}}">
                    <Setter Property="Background" Value="#2D2D2D" />
                    <Setter Property="Foreground" Value="#D4D4D4" />
                    <Setter Property="BorderBrush" Value="#3F3F3F" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </docs:DocsEditor.Resources>
        </docs:DocsEditor>
    </DockPanel>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{x:Static ApplicationCommands.New}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{x:Static ApplicationCommands.Open}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{x:Static ApplicationCommands.Save}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="New_Click" />
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="Open_Click" />
        <CommandBinding Command="{x:Static ApplicationCommands.Save}" Executed="Save_Click" />
    </Window.CommandBindings>
</Window>
