<UserControl x:Class="RaisinDocs.DocsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RaisinDocs"
             Focusable="False">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <DockPanel>
        <local:DocsFormattingBar DockPanel.Dock="Top"
                                Canvas="{Binding ElementName=PART_Canvas}"
                                Visibility="{Binding ShowToolbar, RelativeSource={RelativeSource AncestorType=local:DocsEditor}, Converter={StaticResource BoolToVis}}" />
        <local:DocsCanvas x:Name="PART_Canvas"
                          Theme="{Binding Theme, RelativeSource={RelativeSource AncestorType=local:DocsEditor}, Mode=TwoWay}" />
    </DockPanel>
</UserControl>
