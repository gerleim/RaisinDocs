<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RaisinDocs">

    <Style x:Key="FormattingToggle" TargetType="ToggleButton">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#CCC" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#20000000" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#30000000" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#999" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SplitButtonPart" TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#20000000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FormattingButton" TargetType="Button">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#CCC" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#20000000" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SeparatorLine" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Margin" Value="4,4" />
        <Setter Property="Background" Value="#40000000" />
    </Style>

    <Style TargetType="{x:Type local:DocsFormattingBar}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DocsFormattingBar}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="4,2">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="PART_Bold" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Bold (Ctrl+B)">
                                <TextBlock FontWeight="Bold" Text="B" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_Italic" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Italic (Ctrl+I)">
                                <TextBlock FontStyle="Italic" Text="I" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_Strikethrough" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Strikethrough">
                                <TextBlock TextDecorations="Strikethrough" Text="S" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_Code" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Code" FontFamily="Cascadia Mono,Consolas">
                                <TextBlock Text="&lt;/&gt;" FontSize="11" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_CodeBlock" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Code block" FontFamily="Cascadia Mono,Consolas">
                                <TextBlock Text="```" FontSize="11" />
                            </ToggleButton>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <ToggleButton x:Name="PART_H1" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Heading 1">
                                <TextBlock Text="H1" FontWeight="Bold" FontSize="13" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_H2" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Heading 2">
                                <TextBlock Text="H2" FontWeight="Bold" FontSize="12" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_H3" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Heading 3">
                                <TextBlock Text="H3" FontWeight="Bold" FontSize="11" />
                            </ToggleButton>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <ToggleButton x:Name="PART_Bullet" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Bullet list">
                                <Path x:Name="PART_BulletIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_TaskList" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Task list">
                                <Path x:Name="PART_TaskListIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>
                            <ToggleButton x:Name="PART_Quote" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Blockquote">
                                <Path x:Name="PART_QuoteIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>
                            <Button x:Name="PART_Link" Style="{StaticResource FormattingButton}"
                                    ToolTip="Link (Ctrl+K)">
                                <Path x:Name="PART_LinkIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}"
                                      StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" />
                            </Button>
                            <Button x:Name="PART_InsertTable" Style="{StaticResource FormattingButton}"
                                    ToolTip="Insert table">
                                <Path Width="14" Height="14" Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}"
                                      StrokeThickness="1.5"
                                      Data="M1,1 H15 V13 H1 Z M1,7 H15 M8,1 V13" />
                            </Button>
                            <Button x:Name="PART_ColorText" Style="{StaticResource FormattingButton}"
                                    ToolTip="Text color">
                                <Grid Width="16" Height="16">
                                    <TextBlock Text="A" FontWeight="Bold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-1,0,0"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                                    <Border x:Name="PART_ColorBar" Height="3" VerticalAlignment="Bottom"
                                            Background="Red" CornerRadius="1" />
                                </Grid>
                            </Button>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <ToggleButton x:Name="PART_EditMode" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Source mode (Ctrl+M)">
                                <Path x:Name="PART_EditModeIcon"
                                      Width="16" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <Border x:Name="PART_ImagePreviewBorder"
                                    BorderBrush="#CCC" BorderThickness="1" CornerRadius="3"
                                    Margin="1,0" Height="28" ToolTip="Image Preview: Off">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="PART_ImagePreview" Style="{StaticResource SplitButtonPart}"
                                            Padding="6,2,2,2">
                                        <Path x:Name="PART_ImagePreviewIcon"
                                              Width="16" Height="14" Stretch="Uniform"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                                    </Button>
                                    <Border Width="1" Background="#40000000" Margin="0,4" />
                                    <Button x:Name="PART_ImagePreviewArrow" Style="{StaticResource SplitButtonPart}"
                                            Padding="2,2,4,2">
                                        <Path Width="10" Height="10" Stretch="Uniform"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}"
                                              StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Data="M3,5 L8,10 L13,5" />
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <ToggleButton x:Name="PART_Theme" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Switch to dark theme">
                                <Path x:Name="PART_ThemeIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>

                            <Border Style="{StaticResource SeparatorLine}" />

                            <ToggleButton x:Name="PART_Minimap" Style="{StaticResource FormattingToggle}"
                                          ToolTip="Minimap">
                                <Path x:Name="PART_MinimapIcon"
                                      Width="14" Height="14" Stretch="Uniform"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=local:DocsFormattingBar}}" />
                            </ToggleButton>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
